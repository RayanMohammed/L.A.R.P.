# L.A.R.P. — start your resume this week
#
# Copy this file to .env.local (gitignored) and fill in the values.
# After changing env vars, restart `npm run dev`.

# Groq — required. The /api/plan endpoint calls Groq to generate the action plan.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional. Override the model used by /api/plan.
# Default: llama-3.3-70b-versatile
# GROQ_MODEL=
